<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KINESIS PHOTOBOOTH</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@600&display=swap');
        
        body {
            background-color: #050505;
            color: #eeeeee;
            font-family: 'Cinzel', serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        h1 { letter-spacing: 0.2em; font-size: 2rem; border-bottom: 1px solid #333; padding-bottom: 10px; }
        .camera-container {
            position: relative;
            width: 320px;
            height: 400px;
            background: #111;
            border: 2px solid #333;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.05);
        }
        video { width: 100%; height: 100%; object-fit: cover; filter: grayscale(30%) contrast(120%); }
        /* 여기에 디자인한 프레임 이미지를 덧씌웁니다 */
        .frame-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            /* background-image: url('kinesis_frame.png'); */
            /* background-size: cover; */
            border: 8px solid #1a1a1a;
            box-sizing: border-box;
        }
        button {
            margin-top: 30px;
            padding: 12px 30px;
            background-color: transparent;
            color: #fff;
            border: 1px solid #555;
            font-family: 'Cinzel', serif;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        button:hover { background-color: #eee; color: #000; }
        canvas { display: none; }
    </style>
</head>
<body>

    <h1>KINESIS</h1>
    
    <div class="camera-container">
        <video id="video" autoplay playsinline></video>
        <div class="frame-overlay"></div>
    </div>

    <button id="captureBtn">CAPTURE</button>
    <canvas id="canvas" width="320" height="400"></canvas>

    <script>
        const video = document.getElementById('video');
        const canvas = document.getElementById('canvas');
        const captureBtn = document.getElementById('captureBtn');

        // 웹캠 연결
        navigator.mediaDevices.getUserMedia({ video: true })
            .then(stream => { video.srcObject = stream; })
            .catch(err => { console.error("Camera access denied:", err); });

        // 캡처 기능
        captureBtn.addEventListener('click', () => {
            const context = canvas.getContext('2d');
            // 비디오 화면 캔버스에 그리기
            context.drawImage(video, 0, 0, canvas.width, canvas.height);
            
            // 이미지 다운로드
            const dataUrl = canvas.toDataURL('image/png');
            const link = document.createElement('a');
            link.href = dataUrl;
            link.download = 'kinesis_photo.png';
            link.click();
        });
    </script>
</body>
</html>
